<div class="mb-4 border-b border-gray-200 pb-2">
  <h2 class="text-2xl font-semibold text-gray-900"><%= current_record.new_record? ? "新規登録" : "編集" %></h2>

</div>
<%= form_with(model: [ns_prefix, current_record]) do |form| %>
  <%= render partial: "error_messages", locals: {form: form} %>
  <% if false %>
    <%# かならず確認画面に行くにはここを有効にする %>
    <%= hidden_field_tag(:_goto_confirm, "true") %>
  <% end %>
  <%= render partial: "form", locals: {form: form} %>

  <div class="mb-4">
    <div class="flex flex-wrap gap-2">
      <%= form.submit(name: :_submit, class: "inline-flex items-center justify-center rounded-md border border-transparent bg-blue-600 px-3 py-2 text-sm font-medium text-white shadow-sm hover:bg-blue-700") %>
      <% if controller.respond_to_confirm? %>
        <%= form.submit("確認", name: :_goto_confirm, class: "inline-flex items-center justify-center rounded-md border border-gray-300 bg-white px-3 py-2 text-sm font-medium text-gray-700 shadow-sm hover:bg-gray-50") %>

      <% end %>
    </div>
  </div>
<% end %>
<hr>
<%= link_to("一覧", [ns_prefix, current_plural_key], class: "inline-flex items-center justify-center rounded-md border border-gray-300 bg-white px-3 py-2 text-sm font-medium text-gray-700 shadow-sm hover:bg-gray-50") %>
<% if current_record.persisted? %>
  <%= link_to("詳細", [ns_prefix, current_record], class: "inline-flex items-center justify-center rounded-md border border-sky-600 bg-sky-600 px-3 py-2 text-sm font-medium text-white shadow-sm hover:bg-sky-700") %>
<% end %>
<% if controller.respond_to_destroy? && current_record.persisted? %>
  <%= link_to("削除", [ns_prefix, current_record], method: :delete, data: {confirm: "本当に削除してもよいですか？"}, class: "inline-flex items-center justify-center rounded-md border border-transparent bg-red-600 px-3 py-2 text-sm font-medium text-white shadow-sm hover:bg-red-700") %>

<% end %>
<%= render partial: "crud_debug" %>
