<% form.object.class.columns.each do |column| %>
  <% next if column.name.in?(["id", "created_at", "updated_at"]) %>
  <div class="field">
    <%= form.label(column.name, class: "label") %>
    <div class="col-md-10">
      <% if column.type == :text %>
        <%= form.text_area(column.name, class: "textarea", rows: 8) %>
      <% else %>
        <%= form.text_field(column.name, class: "input") %>
      <% end %>
    </div>
  </div>
<% end %>
