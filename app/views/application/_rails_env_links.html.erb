<% if Rails.env.development? %>
  <div class="navbar-item has-dropdown is-hoverable">
    <div class="navbar-link">
      stage
    </div>
    <div class="navbar-dropdown is-boxed is-right">
      <%= link_to("development", "http://localhost:3000/", class: ["navbar-item", Rails.env.development? ? "is-active" : '']) %>
      <%= link_to("staging", staging_app_url, class: ["navbar-item", Rails.env.staging? ? "is-active" : '']) %>
      <%= link_to("production", production_app_url, class: ["navbar-item", Rails.env.production? ? "is-active" : '']) %>
    </div>
  </div>
<% end %>
