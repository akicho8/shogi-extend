<div class="field">
  <%= form.label(:name, class: "label") %>
  <div class="control">
    <%= form.text_field(:name, class: "input", required: true) %>
  </div>
</div>
<div class="field">
  <%= form.label(:email, class: "label") %>
  <div class="control">
    <%= form.email_field(:email, class: "input", required: true) %>

  </div>
</div>
