<div class="mb-4">
  <%= form.label(:name, class: "mb-1 block text-sm font-medium text-gray-700") %>
  <div>
    <%= form.text_field(:name, class: "block w-full rounded-md border border-gray-300 bg-white px-3 py-2 text-sm text-gray-900 shadow-sm focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-500/30", required: true) %>
  </div>
</div>
<div class="mb-4">
  <%= form.label(:email, class: "mb-1 block text-sm font-medium text-gray-700") %>
  <div>
    <%= form.email_field(:email, class: "block w-full rounded-md border border-gray-300 bg-white px-3 py-2 text-sm text-gray-900 shadow-sm focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-500/30", required: true) %>

  </div>
</div>
<%# = form.fields_for(:profile) do |form| %>
<%# = form.label(:twitter_key, class: "mb-1 block text-sm font-medium text-gray-700") %>
<%# = form.text_field(:twitter_key, class: "block w-full rounded-md border border-gray-300 bg-white px-3 py-2 text-sm text-gray-900 shadow-sm focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-500/30") %>
<%# = form.label(:description, class: "mb-1 block text-sm font-medium text-gray-700") %>
<%# = form.text_area(:description, class: "block w-full rounded-md border border-gray-300 bg-white px-3 py-2 text-sm text-gray-900 shadow-sm focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-500/30", rows: [form.object.description.to_s.lines.count, 4].max) %>

<div class="mb-4">
  <%= form.label(:avatar, class: "mb-1 block text-sm font-medium text-gray-700") %>
  <div>
    <div class="space-y-3 text-sm text-gray-700">
      <p>
        <%= form.file_field(:avatar) %>
      </p>
      <p>
        <%= image_tag(form.object.avatar_path, size: "128") %>
      </p>
    </div>
  </div>
</div>
