<div class="field">
  <%= form.label(:avatar, class: "label") %>
  <div class="control">
    <div class="content">
      <p>
        <%= form.file_field(:avatar) %>
      </p>
      <p>
        <%= image_tag(form.object.avatar_path, size: "128") %>
      </p>
    </div>
  </div>
</div>
