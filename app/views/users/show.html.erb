<div class="mb-4 text-xl font-semibold text-gray-900">
  <%= "#{current_record.name}さんのプロフィール" %>
</div>
<hr>

<div class="grid gap-4">
  <div class="w-full md:w-1/4">
    <%= image_tag(current_record.avatar_path, size: "100%") %>
    <% if current_user == current_record %>
      <div class="mt-3 space-y-3 text-sm text-gray-700">
        <p>
          <%= link_to("編集", [:edit, current_record], class: "inline-flex items-center justify-center rounded-md border border-blue-600 bg-white px-3 py-2 text-sm font-medium text-blue-700 shadow-sm hover:bg-blue-50") %>
          <% if Rails.env.development? %>
            <%= link_to("一覧", [current_plural_key]) %>
            <%= button_to("削除", [current_record], method: :delete, data: {confirm: "本当に削除してもよいですか？"}) %>
          <% end %>
        </p>
      </div>
    <% end %>
  </div>
</div>
