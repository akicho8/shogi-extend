<div class="mb-4 text-xl font-semibold text-gray-900">
  管理画面

</div>
<div class="space-y-3 text-sm text-gray-700">
  <ul>
    <li>ログイン: <%= admin_user.inspect %></li>

  </ul>
</div>
<div class="flex flex-wrap gap-2">
  <%= button_to("ログアウト", [:admin, :session], method: :delete, :class => "inline-flex items-center justify-center rounded-md border border-gray-300 bg-white px-2.5 py-1.5 text-xs font-medium text-gray-700 shadow-sm hover:bg-gray-50") if admin_user %>
  <%= link_to("BASIC認証強制失敗", [:admin, :root, invalidate_basic_auth: true], :class => "inline-flex items-center justify-center rounded-md border border-gray-300 bg-white px-2.5 py-1.5 text-xs font-medium text-gray-700 shadow-sm hover:bg-gray-50" ) %>
  <%= link_to("スクリプト", [:admin, :script, id: :index], :class => "inline-flex items-center justify-center rounded-md border border-gray-300 bg-white px-2.5 py-1.5 text-xs font-medium text-gray-700 shadow-sm hover:bg-gray-50") %>

</div>
<div class="mt-4 rounded-lg border border-gray-200 bg-white p-4 shadow-sm">
  <%= BackendScript.to_rows(self).to_html %>

</div>
<div class="mt-4 rounded-lg border border-gray-200 bg-white p-4 shadow-sm">
  <%= AtomicScript::ExampleScript.to_rows(self).to_html %>
</div>
